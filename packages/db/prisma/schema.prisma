generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ─────────────────────────────────────────────────────────

enum Role {
  ADMIN
  DOCTOR
}

enum Gender {
  M
  F
  OTRO
}

enum RegisteredVia {
  PANEL
  BOT
  IMPORT
}

enum PatientProgramStatus {
  ACTIVE
  PAUSED
  COMPLETED
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
}

enum ConversationStatus {
  OPEN
  CLOSED
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

// ─── Models ────────────────────────────────────────────────────────

model Doctor {
  id           String   @id @default(uuid()) @db.Uuid
  fullName     String
  email        String   @unique
  passwordHash String
  role         Role     @default(DOCTOR)
  createdAt    DateTime @default(now()) @db.Timestamptz()

  programs         DoctorProgram[]
  enrolledPatients PatientProgram[]

  @@map("doctors")
}

model DoctorProgram {
  id         String   @id @default(uuid()) @db.Uuid
  doctorId   String   @db.Uuid
  programId  String   @db.Uuid
  assignedAt DateTime @default(now()) @db.Timestamptz()

  doctor  Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([doctorId, programId])
  @@index([programId])
  @@map("doctor_programs")
}

model Patient {
  id             String        @id @default(uuid()) @db.Uuid
  fullName       String
  dni            String        @unique
  phone          String?       @unique
  birthDate      DateTime?     @db.Date
  gender         Gender?
  consent        Boolean       @default(true)
  registeredVia  RegisteredVia @default(PANEL)
  whatsappLinked Boolean       @default(false)
  createdAt      DateTime      @default(now()) @db.Timestamptz()

  programs      PatientProgram[]
  reminders     Reminder[]
  conversations Conversation[]

  // phone already has @unique which creates an index — no separate @@index needed
  @@index([fullName])
  @@map("patients")
}

model Program {
  id                    String @id @default(uuid()) @db.Uuid
  name                  String @unique
  description           String
  reminderFrequencyDays Int
  templateMessage       String
  centers               Json   @default("[]") @db.JsonB

  doctorPrograms  DoctorProgram[]
  patientPrograms PatientProgram[]
  reminders       Reminder[]

  @@map("programs")
}

model PatientProgram {
  id                 String               @id @default(uuid()) @db.Uuid
  patientId          String               @db.Uuid
  programId          String               @db.Uuid
  enrolledAt         DateTime             @default(now()) @db.Timestamptz()
  enrolledByDoctorId String               @db.Uuid
  lastControlDate    DateTime?            @db.Date
  nextReminderDate   DateTime             @db.Date
  status             PatientProgramStatus @default(ACTIVE)

  patient          Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  program          Program @relation(fields: [programId], references: [id], onDelete: Restrict)
  enrolledByDoctor Doctor  @relation(fields: [enrolledByDoctorId], references: [id], onDelete: Restrict)

  @@unique([patientId, programId])
  @@index([patientId])
  @@index([programId])
  @@index([enrolledByDoctorId])
  @@index([status, nextReminderDate])
  @@map("patient_programs")
}

model Reminder {
  id             String         @id @default(uuid()) @db.Uuid
  patientId      String         @db.Uuid
  programId      String         @db.Uuid
  message        String
  scheduledFor   DateTime       @db.Date
  sentAt         DateTime?      @db.Timestamptz()
  status         ReminderStatus @default(PENDING)
  patientReplied Boolean        @default(false)

  createdAt DateTime @default(now()) @db.Timestamptz()

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  program Program @relation(fields: [programId], references: [id], onDelete: Restrict)

  @@index([patientId])
  @@index([programId])
  @@index([status, scheduledFor])
  @@index([sentAt])
  @@map("reminders")
}

model Conversation {
  id        String             @id @default(uuid()) @db.Uuid
  patientId String?            @db.Uuid
  phone     String
  status    ConversationStatus @default(OPEN)
  startedAt DateTime           @default(now()) @db.Timestamptz()
  closedAt  DateTime?          @db.Timestamptz()

  patient  Patient?  @relation(fields: [patientId], references: [id], onDelete: SetNull)
  messages Message[]

  @@index([patientId])
  @@index([phone])
  @@index([status])
  @@map("conversations")
}

model Message {
  id             String      @id @default(uuid()) @db.Uuid
  conversationId String      @db.Uuid
  role           MessageRole
  content        String
  createdAt      DateTime    @default(now()) @db.Timestamptz()

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}
