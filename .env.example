# ─── Base de datos ───────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/ips_asistente

# ─── Auth ────────────────────────────────────────────────────────
JWT_SECRET=cambiar-por-un-secret-seguro-de-64-chars-minimo
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── WhatsApp (Meta Cloud API) ───────────────────────────────────
WHATSAPP_ACCESS_TOKEN=tu-token-de-meta
WHATSAPP_PHONE_NUMBER_ID=tu-phone-number-id
WHATSAPP_VERIFY_TOKEN=un-string-cualquiera-para-verificacion
WHATSAPP_APP_SECRET=tu-app-secret-de-meta

# ─── AI (Anthropic) ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxx

# ─── Server ──────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── Cron ────────────────────────────────────────────────────────
# Hora de envío de recordatorios (formato cron, default 8:00 AM Argentina UTC-3 = 11:00 UTC)
REMINDER_CRON=0 11 * * *
